# Copy this file to .env and fill in your actual values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe Configuration (publishable key only - secret keys are in Supabase Edge Functions)
# See PAYMENT_SETUP.md for Edge Function secrets (STRIPE_SECRET_KEY)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Development Mode (set to false for production)
EXPO_PUBLIC_DEV_MODE=false

# USE_FAKE_PAYMENT: when true, QuoteAcceptScreen inserts booking without Stripe (testing only). Set false for production.
EXPO_PUBLIC_USE_FAKE_PAYMENT=false

# Demo Mode: when true, feed shows only 3 demo videos (fixed, hourly, contact booking forms). Set false for production.
EXPO_PUBLIC_DEMO_MODE=false

# Google Places/Maps API (for address autocomplete on Post Job, Booking Summary, etc.)
# Enable "Places API" and "Geocoding API" in Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
